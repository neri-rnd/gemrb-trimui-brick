+PyDoc_STRVAR(GemRB_TextArea_GetScrollInfo__doc,
+	     "===== TextArea_GetScrollInfo =====\n\
+\n\
+**Metaclass Prototype:** GetScrollInfo ()\n\
+\n\
+**Description:** Returns scroll state of the TextArea as a dict with keys: content, visible, pos.\n\
+\n\
+**Return value:** dict with int values");
+
+static PyObject* GemRB_TextArea_GetScrollInfo(PyObject* self, PyObject* args)
+{
+	PARSE_ARGS(args, "O", &self);
+	TextArea* ta = GetView<TextArea>(self);
+	ABORT_IF_NULL(ta);
+
+	auto info = ta->GetScrollInfo();
+	PyObject* dict = PyDict_New();
+	PyDict_SetItemString(dict, "content", DecRef(PyLong_FromLong, info.contentHeight));
+	PyDict_SetItemString(dict, "visible", DecRef(PyLong_FromLong, info.visibleHeight));
+	PyDict_SetItemString(dict, "pos", DecRef(PyLong_FromLong, info.scrollPos));
+	return dict;
+}
