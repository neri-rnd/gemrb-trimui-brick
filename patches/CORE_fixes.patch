diff --git a/gemrb/core/GUI/Window.cpp b/gemrb/core/GUI/Window.cpp
index 400c41c..ad74b21 100644
--- a/gemrb/core/GUI/Window.cpp
+++ b/gemrb/core/GUI/Window.cpp
@@ -24,6 +24,7 @@
 #include "Interface.h"
 #include "WindowManager.h"

+#include "GUI/GameControl.h"
 #include "GUI/GUIScriptInterface.h"
 #include "Logging/Logging.h"

@@ -342,6 +343,11 @@ bool Window::HitTest(const Point& p) const
 {
 	bool hit = View::HitTest(p);
 	if (hit == false) {
+		// During cutscene/dialogue, IgnoreEvents windows must not receive
+		// events via child controls (blocks portrait selection in cutscenes)
+		if ((flags & IgnoreEvents) && core->InCutSceneMode()) {
+			return false;
+		}
 		// check the control list. we could make View::HitTest optionally recursive, but this is cheaper
 		for (const auto& ctrl : Controls) {
 			if (ctrl->IsVisible() && ctrl->View::HitTest(ctrl->ConvertPointFromWindow(p))) {
@@ -586,7 +592,9 @@ bool Window::DispatchEvent(const Event& event)
 			if (target == this) {
 				// skip the usual dispatch
 				// this is so that we can move windows that otherwise ignore events
-				OnMouseDrag(event.mouse);
+				if (event.mouse.buttonStates) {
+					OnMouseDrag(event.mouse);
+				}
 			} else {
 				DispatchMouseMotion(target, event.mouse);
 			}
@@ -695,6 +703,9 @@ bool Window::OnKeyPress(const KeyboardEvent& key, unsigned short mod)
 	}

 	if (key.keycode == GEM_ESCAPE && mod == 0) {
+		if (core->InCutSceneMode()) {
+			return true; // block Esc during dialogue and cutscene
+		}
 		Close();
 		return true;
 	}
diff --git a/gemrb/core/GUI/GameControl.cpp b/gemrb/core/GUI/GameControl.cpp
index 8a46583..6172cd4 100644
--- a/gemrb/core/GUI/GameControl.cpp
+++ b/gemrb/core/GUI/GameControl.cpp
@@ -464,6 +464,10 @@ void GameControl::WillDraw(const Region& /*drawFrame*/, const Region& /*clip*/)
 	const Map* area = CurrentArea();
 	if (!area) return;

+	// skip interactive highlighting while events are suppressed (cutscene/dialogue)
+	// mirrors the IgnoreEvents check in OnGlobalMouseMove
+	if (Flags() & IgnoreEvents) return;
+
 	int flags = GA_NO_DEAD | GA_NO_UNSCHEDULED | GA_SELECT | GA_NO_ENEMY | GA_NO_NEUTRAL;
 	auto ab = area->GetActorsInRect(SelectionRect(), flags);

@@ -2150,6 +2154,10 @@ void GameControl::TryDefaultTalk() const
 /** Mouse Button Down */
 bool GameControl::OnMouseDown(const MouseEvent& me, unsigned short Mod)
 {
+	if (core->InCutSceneMode()) {
+		return true; // block clicks during dialogue and cutscene
+	}
+
 	if (Mod & GEM_MOD_CTRL) { // debug paint mode
 		return true;
 	}
@@ -2219,6 +2227,10 @@ bool GameControl::ShouldTriggerWorldMap(const Actor* pc) const
 /** Mouse Button Up */
 bool GameControl::OnMouseUp(const MouseEvent& me, unsigned short Mod)
 {
+	if (core->InCutSceneMode()) {
+		return true; // block clicks during dialogue and cutscene
+	}
+
 	if (Mod & GEM_MOD_CTRL) {
 		Point p = ConvertPointFromScreen(me.Pos());
 		DebugPaint(p + viewport.origin, me.button == GEM_MB_MENU);
