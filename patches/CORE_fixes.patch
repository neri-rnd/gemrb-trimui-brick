diff --git a/gemrb/core/Scriptable/Actor.cpp b/gemrb/core/Scriptable/Actor.cpp
index cb3a725..3d03580 100644
--- a/gemrb/core/Scriptable/Actor.cpp
+++ b/gemrb/core/Scriptable/Actor.cpp
@@ -7833,6 +7833,15 @@ void Actor::UpdateActorState()
 	}
 
 	if (anim.empty()) {
+		// Animation data missing for current stance (e.g. Morte has no CONJURE BAM).
+		// Try the auto-switch that GetAnimation() set up, so the actor transitions
+		// to a valid stance instead of staying invisible forever.
+		CharAnimations* ca = GetAnims();
+		if (ca && ca->autoSwitchOnEnd) {
+			HandleActorStance();
+		} else {
+			SetStance(IE_ANI_AWAKE);
+		}
 		UpdateModalState(game->GameTime);
 		return;
 	}
diff --git a/gemrb/plugins/GUIScript/GUIScript.cpp b/gemrb/plugins/GUIScript/GUIScript.cpp
index d536d9a..8964c19 100644
--- a/gemrb/plugins/GUIScript/GUIScript.cpp
+++ b/gemrb/plugins/GUIScript/GUIScript.cpp
@@ -9343,6 +9343,12 @@ static PyObject* GemRB_DragItem(PyObject* /*self*/, PyObject* args)
 		}
 		si = TryToUnequip(actor, core->QuerySlot(Slot), Count);
 		actor->RefreshEffects();
+		// Weapon removed from slot — trigger animation update so PST
+		// re-lookups ANIMS.2da for the new (or empty) weapon
+		int slotEffects = core->QuerySlotEffects(core->QuerySlot(Slot));
+		if (slotEffects == SLOT_EFFECT_MELEE || slotEffects == SLOT_EFFECT_MISSILE) {
+			core->SetEventFlag(EF_UPDATEANIM);
+		}
 		actor->ReinitQuickSlots();
 		core->SetEventFlag(EF_SELECTION);
 	}
