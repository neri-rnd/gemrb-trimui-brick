diff --git a/gemrb/core/GameScript/GSUtils.cpp b/gemrb/core/GameScript/GSUtils.cpp
index e5005fb..patched 100644
--- a/gemrb/core/GameScript/GSUtils.cpp
+++ b/gemrb/core/GameScript/GSUtils.cpp
@@ -923,6 +923,18 @@ void CreateCreatureCore(Scriptable* Sender, Action* parameters, int flags)
 	}
 
 	Map* map = Sender->GetCurrentArea();
+
+	// During cutscenes, remove any pre-existing actor with the same script
+	// name before adding the new one. Prevents duplicates when a cutscene
+	// CreateCreature overlaps an IniSpawn-persisted actor (e.g. AR1500
+	// Hargrimm: IniSpawn places one from a previous visit, cutscene creates
+	// another at its walk-in position — resulting in a static duplicate).
+	const ieVariable& newName = ab->GetScriptName();
+	if (core->InCutSceneMode() && newName[0]) {
+		Actor* existing = map->GetActor(newName, 0);
+		if (existing) existing->DestroySelf();
+	}
+
 	map->AddActor(ab, true);
 	ab->SetPosition(pnt, flags & CC_CHECK_IMPASSABLE);
 	ab->SetOrientation(ClampToOrientation(parameters->int0Parameter), false);
