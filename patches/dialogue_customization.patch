+PyDoc_STRVAR(GemRB_TextArea_SetMargins__doc,
+	     "===== TextArea_SetMargins =====\n\
+\n\
+**Metaclass Prototype:** SetMargins (top, right, bottom, left)\n\
+\n\
+**Description:** Sets the text content margins for a TextArea.\n\
+\n\
+**Parameters:** \n\
+  * top - top margin in pixels\n\
+  * right - right margin in pixels\n\
+  * bottom - bottom margin in pixels\n\
+  * left - left margin in pixels\n\
+\n\
+**Return value:** N/A");
+
+static PyObject* GemRB_TextArea_SetMargins(PyObject* self, PyObject* args)
+{
+	int top, right, bottom, left;
+	PARSE_ARGS(args, "Oiiii", &self, &top, &right, &bottom, &left);
+	TextArea* ta = GetView<TextArea>(self);
+	ABORT_IF_NULL(ta);
+	ta->SetMargins(ContentContainer::Margin(top, right, bottom, left));
+	Py_RETURN_NONE;
+}
+
+PyDoc_STRVAR(GemRB_TextArea_GetScrollBar__doc,
+	     "===== TextArea_GetScrollBar =====\n\
+\n\
+**Metaclass Prototype:** GetScrollBar ()\n\
+\n\
+**Description:** Returns the vertical scrollbar attached to this TextArea, or None.\n\
+\n\
+**Return value:** GScrollBar or None");
+
+static PyObject* GemRB_TextArea_GetScrollBar(PyObject* self, PyObject* args)
+{
+	PARSE_ARGS(args, "O", &self);
+	TextArea* ta = GetView<TextArea>(self);
+	ABORT_IF_NULL(ta);
+
+	ScrollBar* sb = ta->GetScrollBar();
+	if (sb) {
+		const auto* ref = sb->GetScriptingRef();
+		if (ref) {
+			return gs->ConstructObjectForScriptable(ref);
+		}
+	}
+	Py_RETURN_NONE;
+}
