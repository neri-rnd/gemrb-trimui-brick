+// Check if the actor has any other effect from the same source spell.
+// Used to tie color effect lifetime to its sibling stat effects.
+static bool HasSiblingEffect(const Actor* target, const Effect* fx) {
+	if (fx->SourceRef.IsEmpty()) return false;
+	auto f = target->fxqueue.GetFirstEffect();
+	const Effect* eff;
+	while ((eff = target->fxqueue.GetNextEffect(f)) != nullptr) {
+		if (eff != fx && eff->SourceRef == fx->SourceRef) {
+			return true;
+		}
+	}
+	return false;
+}
